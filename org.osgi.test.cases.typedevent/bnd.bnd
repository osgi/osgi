# Set javac settings from JDT prefs
-include: ${includes}/jdt.bnd, ${includes}/osgi.tck.junit-platform.bnd, ${includes}/tck.bnd, ${includes}/cmpn.bnd

-conditionalpackage					= org.osgi.test.support.*
-privatepackage						=  \
	${p}.*
Import-Package: ${-signaturetest}, *

-buildpath: \
	${osgi.annotation.buildpath},\
	org.osgi.test.support;version=project,\
	org.osgi.service.typedevent;version=latest,\
	org.osgi.resource;maven-scope=provided;version='1.0',\
	org.osgi.namespace.implementation;version='1.0',\
	org.osgi.namespace.service;version='1.0',\
	org.osgi.framework;maven-scope=provided;version='1.8',\
	org.osgi.dto;maven-scope=provided;version='1.0',\
	org.osgi.util.promise;version='1.1',\
	org.osgi.util.pushstream;version='1.0',\
	org.osgi.util.function;version='1.2'

-runbundles						= \
    org.osgi.impl.service.log;version=latest, \
    org.osgi.impl.service.cm;version=latest, \
	org.osgi.service.typedevent;version=latest,\
	org.osgi.util.function;version=latest,\
	org.osgi.util.promise;version=latest,\
	org.osgi.util.pushstream;version=latest,\
	org.osgi.util.converter;version=latest,\
	org.apache.aries.typedevent.bus;version='[1.1,2)',\
	org.apache.aries.component-dsl.component-dsl;version='[1.2,2)',\
	slf4j.api;version='[1.7,2)',\
	slf4j.simple;version='[1.7,2)'

-signaturetest                      = org.osgi.service.typedevent
